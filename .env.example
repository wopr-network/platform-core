# Affiliate base URL — optional. Set to enable affiliate signup links with ref param.
AFFILIATE_BASE_URL=https://wopr.network/join?ref=

# Platform UI URL (used for redirect allowlist)
# PLATFORM_UI_URL=https://platform.example.com

# Extra allowed redirect origins (comma-separated, for staging/preview environments)
# EXTRA_ALLOWED_REDIRECT_ORIGINS=https://staging.wopr.bot,https://preview.wopr.bot

# --- Security ---

# Allow nodes to register with private/RFC-1918 IP addresses (10.x, 172.16-31.x, 192.168.x) and IPv6 unique local addresses (fc00::/7).
# WARNING: Only enable this in VPC/private-network deployments where nodes are on a trusted
# internal network. Enabling on public deployments weakens SSRF protections.
# ALLOW_PRIVATE_NODE_HOSTS=false

# --- Affiliate billing caps ---

# Maximum number of referrals an affiliate can earn credit for in a 30-day window (default: 20)
# AFFILIATE_MAX_REFERRALS_30D=20

# Maximum match credits an affiliate can earn in a 30-day window (default: 20000)
# AFFILIATE_MAX_MATCH_CREDITS_30D=20000
