# Affiliate base URL — optional. Set to enable affiliate signup links with ref param.
AFFILIATE_BASE_URL=https://wopr.network/join?ref=

# Platform UI URL (used for redirect allowlist)
# PLATFORM_UI_URL=https://platform.example.com

# Extra allowed redirect origins (comma-separated, for staging/preview environments)
# EXTRA_ALLOWED_REDIRECT_ORIGINS=https://staging.wopr.bot,https://preview.wopr.bot

# --- Security ---

# Allow nodes to register with private/RFC-1918 IP addresses (10.x, 172.16-31.x, 192.168.x) and IPv6 unique local addresses (fc00::/7).
# WARNING: Only enable this in VPC/private-network deployments where nodes are on a trusted
# internal network. Enabling on public deployments weakens SSRF protections.
# ALLOW_PRIVATE_NODE_HOSTS=false

# --- Provider API probe URLs ---
# Override the default health-check/validation endpoints per provider.
# Useful for air-gapped, proxied, or self-hosted deployments.
# ANTHROPIC_API_URL=https://api.anthropic.com/v1/models
# OPENAI_API_URL=https://api.openai.com/v1/models
# GOOGLE_API_URL=https://generativelanguage.googleapis.com/v1/models
# DISCORD_API_URL=https://discord.com/api/v10/users/@me
# ELEVENLABS_API_URL=https://api.elevenlabs.io/v1/user
# DEEPGRAM_API_URL=https://api.deepgram.com/v1/projects

# --- Stripe billing ---
# Billing gracefully degrades when these vars are absent: loadStripeConfig()
# returns null and loadCreditPriceMap() returns an empty map. The platform
# runs normally but Stripe checkout and webhook handling are disabled.

# Required for Stripe API access (test-mode key starts with sk_test_)
# STRIPE_SECRET_KEY=sk_test_...

# Required for verifying Stripe webhook signatures
# STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs for each credit purchase tier.
# Create these in the Stripe Dashboard under Products > WOPR Credits.
# Each maps to a preset tier: $5, $10, $25 (+2%), $50 (+5%), $100 (+10%).
# STRIPE_CREDIT_PRICE_5=price_...
# STRIPE_CREDIT_PRICE_10=price_...
# STRIPE_CREDIT_PRICE_25=price_...
# STRIPE_CREDIT_PRICE_50=price_...
# STRIPE_CREDIT_PRICE_100=price_...

# --- Affiliate billing caps ---

# Maximum number of referrals an affiliate can earn credit for in a 30-day window (default: 20)
# AFFILIATE_MAX_REFERRALS_30D=20

# Maximum match credits an affiliate can earn in a 30-day window (default: 20000)
# AFFILIATE_MAX_MATCH_CREDITS_30D=20000
